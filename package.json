{
    "name": "vue3_webcomponens_assessment",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc && oxfmt --check && oxlint --type-aware --type-check && vite build",
        "preview": "vite preview",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check",
        "lint": "oxlint --type-aware --type-check",
        "lint:fix": "oxlint --fix --type-aware --type-check"
    },
    "devDependencies": {
        "oxfmt": "^0.36.0",
        "oxlint": "^1.51.0",
        "oxlint-tsgolint": "^0.16.0",
        "typescript": "~5.9.3",
        "vite": "npm:rolldown-vite@latest"
    },
    "pnpm": {
        "overrides": {
            "vite": "npm:rolldown-vite@latest"
        }
    },
    "dependencies": {
        "workbox-build": "^7.4.0",
        "workbox-window": "^7.4.0"
    }
}
